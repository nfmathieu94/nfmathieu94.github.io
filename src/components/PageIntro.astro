---
import PageMotif from "./PageMotif.astro";

/** Standard page opener: specimen-tag label, display heading, lede. */
type Motif =
  "tree" | "dna" | "code" | "chart" | "book" | "pen" | "terminal" | "timeline";

interface Props {
  label: string;
  title: string;
  lede?: string;
  /** Optional decorative header motif aligned to the right of the title. */
  motif?: Motif;
}
const { label, title, lede, motif } = Astro.props;
---

<div class="mb-10">
  <div class="flex items-start justify-between gap-6">
    <div>
      <p class="tag-label mb-2">{label}</p>
      <h1 class="font-display text-3xl font-semibold sm:text-4xl">{title}</h1>
    </div>
    {
      motif && (
        <PageMotif
          motif={motif}
          class="mt-1 hidden h-14 w-auto shrink-0 text-moss/70 sm:block"
        />
      )
    }
  </div>
  {lede && <p class="mt-4 max-w-prose text-lg text-ink-muted">{lede}</p>}
</div>
