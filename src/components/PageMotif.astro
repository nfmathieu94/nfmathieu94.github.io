---
/**
 * Small decorative header motif for each section — "nature meets technology."
 * Each is line-art in the herbarium palette (moss stroke via currentColor,
 * lichen-gold accents), drawn in on load and gated by prefers-reduced-motion
 * (see the .draw-stroke / .pop-in / .blink helpers in global.css).
 * Purely ornamental — aria-hidden, no client JS.
 *
 *   tree      About       — branching roots/canopy (a life's growth)
 *   dna       Research    — a DNA double helix with a leaf (sequencing)
 *   code      Software    — a vine threading through </> brackets
 *   chart     Publications— a "data garden": bar chart whose bars are stems
 *   book      Teaching    — a seedling rising from an open book
 *   pen       Blog        — a leaf-nib pen drawing an ink line
 *   terminal  Tutorials   — a prompt with a blinking cursor and a sprout
 *   timeline  CV          — a timeline whose milestones bud into leaves
 */
type Motif =
  "tree" | "dna" | "code" | "chart" | "book" | "pen" | "terminal" | "timeline";

interface Props {
  motif: Motif;
  class?: string;
}
const { motif, class: className } = Astro.props;

const svgAttrs = {
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.7",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  "aria-hidden": "true",
} as const;
---

{
  motif === "tree" && (
    <svg class={className} viewBox="0 0 60 52" {...svgAttrs}>
      <path class="draw-stroke" pathLength="1" d="M30 50V28" />
      <path class="draw-stroke" pathLength="1" d="M30 38C24 34 20 30 17 24" />
      <path class="draw-stroke" pathLength="1" d="M30 34C36 30 40 26 43 20" />
      <path class="draw-stroke" pathLength="1" d="M30 30C27 26 25 22 25 15" />
      <path class="draw-stroke" pathLength="1" d="M30 30C33 25 36 21 38 15" />
      <path class="draw-stroke" pathLength="1" d="M30 50C26 51 22 51 18 51" />
      <path class="draw-stroke" pathLength="1" d="M30 50C34 51 38 51 42 51" />
      <g fill="var(--lichen)" stroke="none">
        <circle class="pop-in" style="--md:.7s" cx="17" cy="24" r="2.4" />
        <circle class="pop-in" style="--md:.85s" cx="43" cy="20" r="2.4" />
        <circle class="pop-in" style="--md:1s" cx="25" cy="15" r="2.4" />
        <circle class="pop-in" style="--md:1.15s" cx="38" cy="15" r="2.4" />
      </g>
    </svg>
  )
}

{
  motif === "dna" && (
    <svg class={className} viewBox="0 0 44 56" {...svgAttrs}>
      <g stroke="var(--lichen)" stroke-width="1.5">
        <path class="pop-in" style="--md:.7s" d="M17 11H27" />
        <path class="pop-in" style="--md:.85s" d="M17 19H27" />
        <path class="pop-in" style="--md:1s" d="M17 37H27" />
        <path class="pop-in" style="--md:1.15s" d="M17 45H27" />
      </g>
      <path
        class="draw-stroke"
        pathLength="1"
        d="M14 4C30 12 30 20 14 28C30 36 30 44 14 52"
      />
      <path
        class="draw-stroke"
        pathLength="1"
        d="M30 4C14 12 14 20 30 28C14 36 14 44 30 52"
      />
      <g class="pop-in" style="--md:1.3s">
        <path d="M14 5C10 2 5 3 4 8C8 9 13 8 14 5Z" fill="var(--moss)" />
      </g>
    </svg>
  )
}

{
  motif === "code" && (
    <svg class={className} viewBox="0 0 72 48" {...svgAttrs}>
      <g stroke="var(--pine)">
        <path class="draw-stroke" pathLength="1" d="M24 14L14 24L24 34" />
        <path class="draw-stroke" pathLength="1" d="M48 14L58 24L48 34" />
        <path class="draw-stroke" pathLength="1" d="M40 11L32 37" />
      </g>
      <path
        class="draw-stroke"
        style="--md:.5s"
        pathLength="1"
        d="M36 45C30 39 42 35 36 29C31 24 40 20 36 13"
      />
      <g class="pop-in" style="--md:1.3s">
        <path
          d="M36 14C33 10 28 10 26 14C29 17 34 17 36 14Z"
          fill="var(--lichen)"
        />
      </g>
    </svg>
  )
}

{
  motif === "chart" && (
    <svg class={className} viewBox="0 0 64 48" {...svgAttrs}>
      <path class="draw-stroke" pathLength="1" d="M8 42H56" />
      <path class="draw-stroke" style="--md:.2s" pathLength="1" d="M16 42V27" />
      <path
        class="draw-stroke"
        style="--md:.35s"
        pathLength="1"
        d="M28 42V19"
      />
      <path class="draw-stroke" style="--md:.5s" pathLength="1" d="M40 42V31" />
      <path
        class="draw-stroke"
        style="--md:.65s"
        pathLength="1"
        d="M52 42V15"
      />
      <g fill="var(--lichen)" stroke="none">
        <circle class="pop-in" style="--md:.9s" cx="16" cy="27" r="2.4" />
        <circle class="pop-in" style="--md:1.05s" cx="28" cy="19" r="2.4" />
        <circle class="pop-in" style="--md:1.2s" cx="40" cy="31" r="2.4" />
        <circle class="pop-in" style="--md:1.35s" cx="52" cy="15" r="2.4" />
      </g>
      <g stroke="var(--moss)">
        <path class="pop-in" style="--md:1.1s" d="M28 24C31 23 33 20 33 17" />
        <path class="pop-in" style="--md:1.4s" d="M52 20C55 19 57 16 57 13" />
      </g>
    </svg>
  )
}

{
  motif === "book" && (
    <svg class={className} viewBox="0 0 64 48" {...svgAttrs}>
      <path
        class="draw-stroke"
        pathLength="1"
        d="M12 34Q22 30 32 34Q42 30 52 34L52 40Q42 36 32 40Q22 36 12 40Z"
      />
      <path class="draw-stroke" style="--md:.2s" pathLength="1" d="M32 34V40" />
      <path class="draw-stroke" style="--md:.4s" pathLength="1" d="M32 32V16" />
      <g stroke="var(--moss)">
        <path
          class="pop-in"
          style="--md:.95s"
          d="M32 24C27 23 23 19 23 14C28 15 32 19 32 24Z"
        />
        <path
          class="pop-in"
          style="--md:1.15s"
          d="M32 20C37 19 41 15 41 10C36 11 32 15 32 20Z"
        />
      </g>
    </svg>
  )
}

{
  motif === "pen" && (
    <svg class={className} viewBox="0 0 64 44" {...svgAttrs}>
      <path
        class="draw-stroke"
        style="--md:.3s"
        pathLength="1"
        d="M12 34C22 31 32 31 44 34"
      />
      <path class="draw-stroke" pathLength="1" d="M27 27L46 7" />
      <g class="pop-in" style="--md:1.1s">
        <path
          d="M27 27C22 26 19 22 20 17C25 18 28 22 27 27Z"
          fill="var(--moss)"
        />
      </g>
      <circle
        class="pop-in"
        style="--md:1.3s"
        cx="46"
        cy="7"
        r="2.2"
        fill="var(--lichen)"
        stroke="none"
      />
    </svg>
  )
}

{
  motif === "terminal" && (
    <svg class={className} viewBox="0 0 64 48" {...svgAttrs}>
      <path class="draw-stroke" pathLength="1" d="M12 12H52V38H12Z" />
      <path class="draw-stroke" style="--md:.3s" pathLength="1" d="M12 19H52" />
      <path
        class="draw-stroke"
        style="--md:.6s"
        pathLength="1"
        d="M19 26L24 30L19 34"
      />
      <rect
        class="blink"
        x="28"
        y="27"
        width="7"
        height="6"
        rx="1"
        fill="var(--lichen)"
        stroke="none"
      />
      <path class="draw-stroke" style="--md:.5s" pathLength="1" d="M44 12V5" />
      <g class="pop-in" style="--md:1.1s">
        <path d="M44 8C48 5 53 6 54 11C50 12 45 11 44 8Z" fill="var(--moss)" />
      </g>
    </svg>
  )
}

{
  motif === "timeline" && (
    <svg class={className} viewBox="0 0 64 44" {...svgAttrs}>
      <path class="draw-stroke" pathLength="1" d="M8 30H56" />
      <path
        class="draw-stroke"
        style="--md:.25s"
        pathLength="1"
        d="M16 30V22"
      />
      <path class="draw-stroke" style="--md:.4s" pathLength="1" d="M32 30V18" />
      <path
        class="draw-stroke"
        style="--md:.55s"
        pathLength="1"
        d="M48 30V24"
      />
      <g stroke="var(--moss)">
        <path
          class="pop-in"
          style="--md:.95s"
          d="M16 22C13 21 11 18 11 14C15 15 17 18 16 22Z"
        />
        <path
          class="pop-in"
          style="--md:1.15s"
          d="M32 18C35 17 37 14 37 10C33 11 31 14 32 18Z"
        />
        <path
          class="pop-in"
          style="--md:1.35s"
          d="M48 24C45 23 43 20 43 16C47 17 49 20 48 24Z"
        />
      </g>
      <g fill="var(--lichen)" stroke="none">
        <circle class="pop-in" style="--md:.85s" cx="16" cy="30" r="2.2" />
        <circle class="pop-in" style="--md:1.05s" cx="32" cy="30" r="2.2" />
        <circle class="pop-in" style="--md:1.25s" cx="48" cy="30" r="2.2" />
      </g>
    </svg>
  )
}
