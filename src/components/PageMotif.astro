---
/**
 * Small decorative header motif for each section — "nature meets technology."
 * Each is line-art in the herbarium palette (moss stroke via currentColor,
 * lichen-gold accents), drawn in on load, then kept subtly alive: leaves
 * sway (.sway) and buds/spores pulse (.pulse-dot). Everything is gated by
 * prefers-reduced-motion (see the motif helpers in global.css).
 * Purely ornamental — aria-hidden, no client JS.
 *
 *   tree      About       — branching roots/canopy (a life's growth)
 *   dna       Research    — a DNA double helix with breathing base pairs
 *   code      Software    — a potted plant thriving between < > brackets
 *   chart     Publications— a "data garden": bar chart whose bars are stems
 *   book      Teaching    — a seedling rising from an open book
 *   pen       Blog        — a leaf-quill whose ink line unfurls into a
 *                           fiddlehead spiral, trailing spores
 *   terminal  Tutorials   — a prompt whose sprout climbs well out of the box
 *   timeline  CV          — a timeline whose milestones bud into leaves
 */
type Motif =
  "tree" | "dna" | "code" | "chart" | "book" | "pen" | "terminal" | "timeline";

interface Props {
  motif: Motif;
  class?: string;
}
const { motif, class: className } = Astro.props;

const svgAttrs = {
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.7",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  "aria-hidden": "true",
} as const;
---

{
  motif === "tree" && (
    <svg class={className} viewBox="0 0 60 52" {...svgAttrs}>
      <path class="draw-stroke" pathLength="1" d="M30 50V28" />
