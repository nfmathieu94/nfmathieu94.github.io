      <path class="draw-stroke" pathLength="1" d="M30 50C26 51 22 51 18 51" />
      <path class="draw-stroke" pathLength="1" d="M30 50C34 51 38 51 42 51" />
      <g fill="var(--lichen)" stroke="none">
        <g class="pop-in" style="--md:.7s">
          <circle class="pulse-dot" cx="17" cy="24" r="2.4" />
        </g>
        <g class="pop-in" style="--md:.85s">
          <circle class="pulse-dot" style="--pd:.8s" cx="43" cy="20" r="2.4" />
        </g>
        <g class="pop-in" style="--md:1s">
          <circle class="pulse-dot" style="--pd:1.6s" cx="25" cy="15" r="2.4" />
        </g>
        <g class="pop-in" style="--md:1.15s">
          <circle class="pulse-dot" style="--pd:2.4s" cx="38" cy="15" r="2.4" />
        </g>
      </g>
    </svg>
  )
}

